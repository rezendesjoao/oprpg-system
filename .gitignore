# Dependências
node_modules/

# Bundle compilado NÃO usado (o sistema carrega dnd5e.mjs direto como ESM)
dnd5e-compiled.mjs
dnd5e-compiled.mjs.map
dnd5e.lock

# Source maps
*.map

# Locks de runtime dos compêndios (LevelDB)
packs/*/LOCK

# Logs de depuração do LevelDB (o Foundry não precisa deles p/ carregar os packs)
packs/*/LOG
packs/*/LOG.old

# Distribuição
dist/
system.zip

# IDE / OS
.idea/
.vscode/
.vs/
.nova/
*.code-workspace
*.iml
*.swp
.DS_Store
Thumbs.db

# NOTA: dnd5e.css e packs/ (LevelDB compilado) SÃO versionados de propósito,
# para que o repositório seja autossuficiente (instala e roda sem build).
