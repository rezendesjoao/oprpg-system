<section class="tab {{ tab.cssClass }} jujutsu-section" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">

  {{!-- ══════════════════════════ MAESTRIA ══════════════════════════ --}}
  <div class="mastery-header jujutsu-treinamento">

    <div class="mastery-top">
      <div class="mastery-badge">
        <span class="level">{{actor.system.masteryLevel}}º</span>
        <span class="label">Maestria</span>
      </div>

      <div class="mastery-info">
        <span>{{#if (eq actor.system.masterySorcerer "special")}}Feiticeiro de Grau Especial{{else}}Feiticeiro {{actor.system.masterySorcerer}} Grau{{/if}}</span>
        {{#if actor.system.masteryDie}}
          <span>Dado de Energia: {{actor.system.masteryDie}}</span>
        {{/if}}
        <span>PT Investidos: {{actor.system.masteryPoints}}</span>
      </div>
    </div>

    {{#if actor.system.masteryLocked}}
    <div class="mastery-lock-banner"
         data-tooltip="Você continua acumulando PT e treinos normalmente, mas o Nível de Maestria não passa do 7º até você Expandir o Domínio com sucesso (botão na barra lateral, 1×/combate, 20 natural).">
      <i class="fas fa-lock" inert></i>
      <span>Travado na <strong>Maestria 7</strong> — expanda seu domínio para progredir além</span>
    </div>
    {{/if}}

    <div class="mastery-bars">
      <div class="bar">
        <label>Pontos de Treinamento</label>
        <input type="number"
          name="system.curseResources.trainingPoints"
          value="{{actor.system.curseResources.trainingPoints}}" />
      </div>
      <div class="bar">
        <label>PT Investidos</label>
        <input type="number"
          value="{{actor.system.masteryPoints}}"
          readonly />
      </div>
      <div class="bar bar-lost">
        <label>PT Perdidos</label>
        <input type="number"
          name="system.curseResources.lostTrainingPoints"
          value="{{actor.system.curseResources.lostTrainingPoints}}" />
      </div>
    </div>

  </div>

  {{!-- ═══════════════════════ TABELA ══════════════════════════════ --}}
  <details class="mastery-table-details">
    <summary>Tabela de Nível de Maestria</summary>
    <table class="mastery-table">
      <thead>
        <tr>
          <th>Nível</th>
          <th>Feiticeiro</th>
          <th>PT</th>
          <th>Dado</th>
          <th>Evolução</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>1º</td><td>4º Grau</td><td>1</td><td>d6</td><td>Técnica Básica</td></tr>
        <tr><td>2º</td><td>3º Grau</td><td>10</td><td>—</td><td>—</td></tr>
        <tr><td>3º</td><td>3º Grau</td><td>20</td><td>d8</td><td>Técnica Inata</td></tr>
        <tr><td>4º</td><td>2º Grau</td><td>35</td><td>—</td><td>—</td></tr>
        <tr><td>5º</td><td>2º Grau</td><td>60</td><td>d10</td><td>Técnica Ritual</td></tr>
        <tr><td>6º</td><td>1º Grau</td><td>75</td><td>—</td><td>—</td></tr>
        <tr><td>7º</td><td>1º Grau</td><td>100</td><td>d12</td><td>Expansão de Domínio</td></tr>
        <tr><td>9º</td><td>Grau Especial</td><td>115</td><td>—</td><td>—</td></tr>
        <tr><td>10º</td><td>Grau Especial</td><td>150</td><td>—</td><td>Expansão sem Barreiras</td></tr>
      </tbody>
    </table>
  </details>

  {{!-- ═══════════════════════ TREINAMENTOS ════════════════════════ --}}
  {{#each trainings as |group groupKey|}}
  <div class="training-section">

    <h3 class="section-header jujutsu-title">
      {{#if (eq groupKey "general")}}
        <span>◆</span> Treinamentos Gerais
      {{/if}}
      {{#if (eq groupKey "domain")}}
        <span>◈</span> Domínio e Anti-Domínio
      {{/if}}
    </h3>

    <div class="training-list">
      {{#each group}}
      <div class="training-card rank-{{this.rank}} {{#if (gte this.rank this.maxRank)}}rank-max{{/if}} {{#unless this.canTrain}}locked{{/unless}}"
           data-training-id="{{@key}}">

        {{!-- Kanji decorativo — injetado via JS pelo _injectTrainingRefs --}}
        <span class="tc-kanji"></span>

        {{!-- Header: dot de status + nome --}}
        <div class="training-header">
          <span class="tc-dot"></span>
          <span class="training-name">{{this.label}}</span>
        </div>

        {{!-- Stars + meta (PT e CD) --}}
        <div class="tc-bottom">
          <div class="training-stars">
            <span class="star {{#if (gte this.rank 1)}}filled{{/if}}">★</span>
            {{#if this.evolutionEffect}}
            <span class="star {{#if (gte this.rank 2)}}filled{{/if}}">★</span>
            {{/if}}
            {{#if this.perfectionEffect}}
            <span class="star {{#if (gte this.rank 3)}}filled{{/if}}">★</span>
            {{/if}}
          </div>
          <div class="jujutsu-meta">
            <span>PT {{this.nextPtCost}}</span>
            <span>CD {{this.currentDC}}</span>
          </div>
        </div>

        {{!-- Ações --}}
        <div class="jujutsu-actions">
          {{#if (gte this.rank this.maxRank)}}
            {{!-- Rank máximo: gif Black Flash + label --}}
            <img class="tc-black-flash-gif"
                 src="systems/onepiece-system/assets/satoru.gif"
                 alt="Black Flash" />
            <span class="max-rank">✦ Perfeição</span>
          {{else if this.canTrain}}
            <button class="jujutsu-btn primary btn-train"
              data-action="trainAbility"
              data-training="{{@key}}">
              Treinar
            </button>
            <button class="jujutsu-btn btn-instant"
              data-action="instantAdvance"
              data-training="{{@key}}">
              Instantâneo
            </button>
          {{else}}
            <span class="cant-train">🔒 {{this.lockReason}}</span>
          {{/if}}
        </div>

      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}

</section>
