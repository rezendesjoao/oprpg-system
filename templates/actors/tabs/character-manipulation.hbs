<section class="tab {{ tab.cssClass }} jujutsu-section" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">

  {{!-- ══════════════════════════════ TOPO ══════════════════════════════ --}}
  <div class="manip-top">

    {{!-- Hexágono de estágio --}}
    <div class="manip-stage-block">
      <div class="manip-stage-hex">
        {{#if (eq actor.system.manipulation.stage "master")}}
          <span>M</span>
        {{else if (eq actor.system.manipulation.stage "expert")}}
          <span>P</span>
        {{else}}
          <span>I</span>
        {{/if}}
      </div>
      {{#if (eq actor.system.manipulation.stage "master")}}
        <span class="manip-stage-lbl">Mestre</span>
      {{else if (eq actor.system.manipulation.stage "expert")}}
        <span class="manip-stage-lbl">Perito</span>
      {{else}}
        <span class="manip-stage-lbl">Iniciante</span>
      {{/if}}
      <span class="manip-stage-pts">{{actor.system.manipulation.pointsInvested}} PM investidos</span>
    </div>

    <div class="manip-right">

      {{!-- PM + efeito do estágio --}}
      <div class="manip-pm-row">
        <div class="manip-pm-left">
          <span class="manip-pm-lbl">Pontos de Maldição</span>
          <input class="manip-pm-val" type="number"
            name="system.curseResources.cursePoints"
            value="{{actor.system.curseResources.cursePoints}}"
            min="0" data-dtype="Number" />
          <span class="manip-pm-desc">
            {{#if (eq actor.system.manipulation.stage "beginner")}}
              Ação bônus para ativar / desativar energia
            {{else if (eq actor.system.manipulation.stage "expert")}}
              Ativação automática · Proficiência em CON
            {{else}}
              +4 dados em descanso longo · Maestria em CON
            {{/if}}
          </span>
        </div>
      </div>

      {{!-- Evolução na Prática — divisória modelo C --}}
      <div class="manip-evo-row">
        <div class="manip-evo-seg {{#if actor.system.energy.intensiveTraining.maxEnergy}}on{{/if}}">
          <span class="manip-evo-lbl">PA Máximo</span>
          <span class="manip-evo-val">+{{actor.system.energy.intensiveTraining.maxEnergy}}</span>
          {{#if actor.system.energy.intensiveTraining.maxEnergy}}
          <button class="manip-evo-undo" data-action="undoIntensiveTraining" data-field="maxEnergy" title="Desfazer">
            <i class="fas fa-rotate-left"></i>
          </button>
          {{/if}}
        </div>
        <div class="manip-evo-seg {{#if actor.system.energy.intensiveTraining.generatedEnergy}}on{{/if}}">
          <span class="manip-evo-lbl">PA Gerada</span>
          <span class="manip-evo-val">+{{actor.system.energy.intensiveTraining.generatedEnergy}}</span>
          {{#if actor.system.energy.intensiveTraining.generatedEnergy}}
          <button class="manip-evo-undo" data-action="undoIntensiveTraining" data-field="generatedEnergy" title="Desfazer">
            <i class="fas fa-rotate-left"></i>
          </button>
          {{/if}}
        </div>
        <div class="manip-evo-seg {{#if actor.system.energy.intensiveTraining.cursePoints}}on{{/if}}">
          <span class="manip-evo-lbl">Pt. Maldição</span>
          <span class="manip-evo-val">+{{actor.system.energy.intensiveTraining.cursePoints}}</span>
          {{#if actor.system.energy.intensiveTraining.cursePoints}}
          <button class="manip-evo-undo" data-action="undoIntensiveTraining" data-field="cursePoints" title="Desfazer">
            <i class="fas fa-rotate-left"></i>
          </button>
          {{/if}}
        </div>
        <div class="manip-evo-btn-wrap">
          <button class="jujutsu-btn primary btn-intensive-training"
            data-action="intensiveTraining"
            title="Iniciar Treinamento Intenso (10 dias)">
            <i class="fas fa-dumbbell"></i> Treinar
          </button>
        </div>
      </div>

    </div>
  </div>

  {{!-- ═══════════════════════════ HABILIDADES ══════════════════════════ --}}
  {{#each abilities as |group groupKey|}}
  <div class="ability-section">

    <h3 class="section-header jujutsu-title">
      {{#if (eq groupKey "basic")}}    <span>◆</span> Habilidades Básicas   {{/if}}
      {{#if (eq groupKey "advanced")}} <span>◆</span> Habilidades Avançadas {{/if}}
      {{#if (eq groupKey "extreme")}}  <span>◈</span> Habilidades Extremas  {{/if}}
      {{#if (eq groupKey "barrier")}}  <span>◇</span> Habilidades de Barreira {{/if}}
    </h3>

    <div class="ability-grid">
      {{#each group}}
      <div class="ability-card {{#if this.unlocked}}unlocked{{else if this.canUnlock}}available{{else}}locked{{/if}}"
           data-ability-id="{{@key}}">

        {{!-- Kanji decorativo — injetado via JS --}}
        <span class="ability-kanji"></span>

        {{!-- Nome + custo --}}
        <span class="ability-name">{{this.label}}</span>
        <div class="ability-meta">
          <span class="ability-cost">{{this.cost}} PM</span>
          {{#if this.stageLabel}}
            <span class="ability-stage stage-badge-{{this.stage}}">{{this.stageLabel}}</span>
          {{/if}}
        </div>

        {{!-- Botão de ação --}}
        <div class="ability-actions">
          {{#if this.unlocked}}
            {{#if this.repeatable}}
              <div class="ability-repeat-row">
                <span class="ability-repeat-count" title="Vezes adquirida">
                  <i class="fas fa-layer-group"></i> {{this.count}}×
                </span>
                {{#if this.canUnlock}}
                  <button class="jujutsu-btn primary btn-unlock"
                    data-action="unlockManipulation"
                    data-ability="{{@key}}"
                    data-cost="{{this.cost}}">
                    + Adquirir · {{this.cost}} PM
                  </button>
                {{else}}
                  <button class="jujutsu-btn locked-state" disabled>🔒 {{this.lockReason}}</button>
                {{/if}}
              </div>
            {{else}}
              <button class="jujutsu-btn unlocked-state" disabled>✓ Desbloqueado</button>
            {{/if}}
          {{else if this.canUnlock}}
            <button class="jujutsu-btn primary btn-unlock"
              data-action="unlockManipulation"
              data-ability="{{@key}}"
              data-cost="{{this.cost}}">
              Desbloquear · {{this.cost}} PM{{#if this.fetoDiscount}} <span class="jj-feto-badge" title="Desconto Feto Amaldiçoado">½</span>{{/if}}
            </button>
          {{else}}
            <button class="jujutsu-btn locked-state" disabled>🔒 {{this.lockReason}}</button>
          {{/if}}
        </div>

        {{!-- Divisória + técnicas (sempre presente) --}}
        <div class="ability-footer">
          {{#each this.techniques}}
            <span class="ability-tech-pill">{{this}}</span>
          {{/each}}
        </div>

      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}

</section>
