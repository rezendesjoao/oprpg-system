<section class="flexcol">
    <div class="note info">
        {{ localize (ifThen isGroup "DND5E.REST.Short.Hint.Group" "DND5E.REST.Short.Hint.Normal") }}
    </div>

    {{> "dnd5e.formlist" formSections }}

    {{#if hitDice}}
    {{#if hitDice.canRoll}}
    <fieldset>
        <legend>{{ localize "DND5E.HitDice" }}</legend>
        <div class="form-fields">
            <select name="denom">
                {{ selectOptions hitDice.options selected=hitDice.denomination }}
            </select>
            <button type="button" class="dice-button" data-action="rollHitDie" data-tooltip
                    aria-label="{{ localize 'DND5E.Roll' }}">
                <i class="fa-solid fa-dice-d20" inert></i>
            </button>
        </div>
        {{ formField autoRoll name="autoHD" value=config.autoHD input=inputs.createCheckboxInput rootId=partId }}
    </fieldset>
    {{else}}
    <div class="note warn">
        {{ localize "DND5E.REST.HitDice.None" }}
    </div>
    {{/if}}
    {{/if}}

    {{#if energyDice.canRoll}}
    <fieldset>
        <legend>Dados de Poder</legend>
        <div class="form-fields">
            <select name="energyDenom">
                {{#each energyDice.options}}
                <option value="{{ value }}">{{ label }}</option>
                {{/each}}
            </select>
            <button type="button" class="dice-button" data-action="rollEnergyDie" data-tooltip
                    aria-label="Roll Energy Die">
                <i class="fa-solid fa-dice-d20" inert></i>
            </button>
        </div>
        {{ formField autoEnergyRoll name="autoEnergyED" value=config.autoEnergyED input=inputs.createCheckboxInput rootId=partId }}
    </fieldset>
    {{else if energyDice}}
    <div class="note warn">
        Sem Dados de Poder disponíveis.
    </div>
    {{/if}}

    {{#if request}}
    {{> "systems/onepiece-system/templates/actors/rest/parts/rest-request.hbs" }}
    {{/if}}
</section>