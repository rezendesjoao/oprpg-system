<div class="sidebar">

    {{!-- Character Card --}}
    <div class="card">

        {{!-- Collapser --}}
        <button type="button" class="sidebar-collapser collapser card-tab vertical unbutton always-interactive"
            {{~#if sidebarCollapsed}} data-tooltip="JOURNAL.ViewExpand" aria-label="{{ localize 'JOURNAL.ViewExpand' }}"
            {{~else}} data-tooltip="JOURNAL.ViewCollapse" aria-label="{{ localize 'JOURNAL.ViewCollapse' }}"{{/if}}
            data-action="toggleSidebar">
            <i class="fas fa-caret-{{#if sidebarCollapsed}}right{{else}}left{{/if}}" inert></i>
        </button>

        {{!-- Portrait --}}
        <div class="portrait {{#if portrait.token}}token{{/if}}">
            {{#if editable}}
            <label class="slide-toggle roboto-upper">
                <input type="checkbox" name="flags.OnePiece.showTokenPortrait" {{ checked portrait.token }}>
                {{#if portrait.token}}
                <i class="fas fa-toggle-on" inert></i>
                {{ localize "DOCUMENT.Token" }}
                {{else}}
                <i class="fas fa-toggle-off" inert></i>
                {{ localize "DND5E.Portrait" }}
                {{/if}}
            </label>
            {{/if}}

            {{#with portrait}}
            {{#if isVideo}}
            <video src="{{ src }}" autoplay muted disablepictureinpicture loop playsinline
                   {{#if @root.editable}}data-action="{{ action }}"{{else}}data-action="showArtwork"{{/if}}
                   {{#if (and @root.editable path)}}data-edit="{{ path }}" data-type="{{ type }}"{{/if}}></video>
            {{else}}
            <img src="{{ src }}" alt="{{ @root.actor.name }}"
                 {{#if @root.editable}}data-action="{{ action }}"{{else}}data-action="showArtwork"{{/if}}
                 {{#if (and @root.editable path)}}data-edit="{{ path }}" data-type="{{ type }}"{{/if}}>
            {{/if}}
            {{/with}}
        </div>

        {{!-- Stats --}}
        <div class="stats">

            {{!-- AC & Exhaustion --}}
            <div class="top">

                {{#if exhaustion}}
                <div class="pips" data-prop="system.attributes.exhaustion">
                    {{#each exhaustion.left}}
                    {{> ".pip" }}
                    {{/each}}
                </div>
                {{/if}}

                {{!-- AC --}}
                <div class="ac-badge badge" aria-label="{{ localize 'DND5E.ArmorClass' }}">
                    {{#if editable}}
                    <button type="button" class="config-button unbutton" data-action="showConfiguration"
                            data-config="armorClass" data-tooltip="DND5E.ArmorConfig"
                            aria-label="{{ localize 'DND5E.ArmorConfig' }}">
                        <i class="fas fa-cog" inert></i>
                    </button>
                    {{else}}
                    <div data-attribution="attributes.ac" data-attribution-caption="DND5E.ArmorClass"
                         data-tooltip-direction="DOWN">
                        {{ system.attributes.ac.value }}
                    </div>
                    {{/if}}
                </div>

                {{#if exhaustion}}
                <div class="pips" data-prop="system.attributes.exhaustion">
                    {{#each exhaustion.right}}
                    {{> ".pip" }}
                    {{/each}}
                </div>
                {{/if}}
            </div>

            {{!-- Initiative, Speed, & Proficiency --}}
            <div class="lozenges">

                {{!-- Initiative --}}
                <div class="lozenge {{#unless editable}}{{ rollableClass }}{{/unless}}"
                     data-action="roll" data-type="initiative">
                    <div class="value">
                        {{#if editable}}
                        <button type="button" class="config-button unbutton" data-action="showConfiguration"
                                data-config="initiative" data-tooltip="DND5E.InitiativeConfig"
                                aria-label="{{ localize 'DND5E.InitiativeConfig' }}">
                            <i class="fas fa-cog" inert></i>
                        </button>
                        {{else}}
                        <span>
                            {{ dnd5e-numberFormat system.attributes.init.total signDisplay="always" }}
                        </span>
                        {{/if}}
                    </div>
                    <div class="label roboto-condensed-upper">{{ localize "DND5E.Initiative" }}</div>
                </div>

                {{!-- Speed --}}
                <div class="lozenge" data-attribution="attributes.movement">
                    <div class="value">
                        {{#if editable}}
                        <button type="button" class="config-button unbutton" data-action="showConfiguration"
                                data-config="movement" data-tooltip="DND5E.MOVEMENT.Action.Configure">
                            <i class="fas fa-cog" inert></i>
                        </button>
                        {{else}}
                        {{ speed.value }}
                        {{/if}}
                    </div>
                    <div class="label roboto-condensed-upper">{{ speed.label }}</div>
                </div>

                {{!-- Proficiency --}}
                <div class="lozenge">
                    <div class="value">
                        {{ dnd5e-numberFormat system.attributes.prof signDisplay="always" }}
                    </div>
                    <div class="label roboto-condensed-upper">{{ localize "DND5E.Proficiency" }}</div>
                </div>
            </div>

           {{!-- Hit Points --}}
<div class="meter-group">
  <div class="label roboto-condensed-upper">
    <span>{{ localize "DND5E.HitPoints" }}</span>
    {{#if editable}}
    <button type="button" class="config-button unbutton" data-action="showConfiguration"
            data-config="hitPoints" data-tooltip="DND5E.HitPointsConfig"
            aria-label="{{ localize 'DND5E.HitPointsConfig' }}">
      <i class="fas fa-cog" inert></i>
    </button>
    {{/if}}
  </div>
  <div style="display: flex; gap: 4px;">
    {{#with system.attributes.hp}}
    <div class="meter sectioned hit-points" style="flex: 1;">
      <div class="progress hit-points
           {{~#if (gt tempmax 0)}} temp-positive
           {{~else if (lt tempmax 0)}} temp-negative{{/if}}"
           role="meter" aria-valuemin="0" aria-valuenow="{{ value }}"
           aria-valuemax="{{ max }}" style="--bar-percentage: {{ pct }}%">
        <div class="label">
          <span class="value">{{ value }}</span>
          <span class="separator">&sol;</span>
          <span class="max">{{ effectiveMax }}</span>
          {{#if tempmax}}
          <span class="bonus">{{dnd5e-numberFormat tempmax signDisplay="always"}}</span>
          {{/if}}
        </div>
        <input type="text" name="system.attributes.hp.value" data-dtype="Number"
               data-max="{{ ifThen effectiveMax effectiveMax max }}"
               placeholder="0" value="{{ value }}" hidden>
      </div>
      <div class="tmp">
        <input type="text" name="system.attributes.hp.temp" data-dtype="Number"
               placeholder="{{ localize 'DND5E.TMP' }}"
               value="{{#if temp}}{{ temp }}{{/if}}">
      </div>
    </div>
    {{/with}}

  </div>
</div>
            
{{!-- Cursed Energy --}}
<div class="meter-group">
  <div class="label roboto-condensed-upper" style="display: flex; justify-content: space-between;">
    <span>Pontos de Poder</span>
    {{#if editable}}
    <button type="button" class="config-button unbutton" data-action="showConfiguration"
            data-config="cursedEnergy" data-tooltip="JUJUTSU.Energy.Config"
            aria-label="Cursed Energy Config">
      <i class="fas fa-cog" inert></i>
    </button>
    {{/if}}
    <span>PP Gerado</span>
  </div>
  <div style="display: flex; gap: 4px;">
    {{#with system.energy}}
    <div class="meter sectioned hit-points cursed-energy-bar" style="flex: 2;">
      <div class="progress hit-points" role="meter" aria-valuemin="0" aria-valuenow="{{ total }}"
           aria-valuemax="{{ max }}" style="--bar-percentage: {{ @root.energyPct }}%">
        <div class="label">
          <span class="value">{{ total }}</span>
          <span class="separator">&sol;</span>
          <span class="max">{{ max }}</span>
        </div>
        <input type="text" name="system.energy.total" data-dtype="Number"
               placeholder="0" value="{{ total }}" hidden>
      </div>
    </div>
    <div class="meter sectioned hit-points" style="flex: 1; --dnd5e-color-hp-1: #2a6aaa; --dnd5e-color-hp-2: #4a90d9; --dnd5e-color-hp-3: #3a80c9;">
      <div class="progress hit-points" role="meter" style="--bar-percentage: 100%">
        <div class="label">
          <input type="text" name="system.energy.generated" data-dtype="Number"
                 placeholder="0" value="{{ generated }}"
                 style="background:transparent; border:none; color:inherit; text-align:center; width:100%;">
        </div>
      </div>
    </div>
    {{/with}}
  </div>
</div>

            {{!-- Dice Row --}}
            <div class="meter-group">
                <div class="label roboto-condensed-upper" style="display:flex; justify-content:space-between;">
                    <span>{{ localize "DND5E.HitDice" }}</span>
                    {{#if editable}}
                    <button type="button" class="config-button unbutton" data-action="showConfiguration"
                            data-config="hitDice" data-tooltip="DND5E.HitDiceConfig"
                            aria-label="Dado de Vida Config">
                        <i class="fas fa-cog" inert></i>
                    </button>
                    {{/if}}
                    <span>Dados de Poder</span>
                    {{#if editable}}
                    <button type="button" class="config-button unbutton" data-action="showConfiguration"
                            data-config="cursedEnergyDice" data-tooltip="JUJUTSU.EnergyDice.Config"
                            aria-label="Configurar Dados de Poder">
                        <i class="fas fa-cog" inert></i>
                    </button>
                    {{/if}}
                </div>
                <div style="display:flex; gap:4px;">
                    {{#with system.attributes.hd}}
<div class="meter sectioned hit-points hit-dice-bar" style="flex:1;" role="meter" aria-valuemin="0" aria-valuenow="{{ value }}" aria-valuemax="{{ max }}">
  <div class="progress hit-points hit-dice-bar" role="meter" style="--bar-percentage: {{ pct }}%">
    <div class="label"><span class="value">{{ value }}</span><span class="separator">&sol;</span><span class="max">{{ max }}</span></div>
  </div>
</div>
{{/with}}
                    <div class="meter sectioned hit-points energy-dice-bar" style="flex:1; --dnd5e-color-hp-1: #5a3a7a; --dnd5e-color-hp-2: #8b6aad; --dnd5e-color-hp-3: #7a5a9a;" role="meter" aria-valuemin="0" aria-valuenow="{{ system.energyDice.value }}" aria-valuemax="{{ system.energyDice.max }}">
                      <div class="progress hit-points energy-dice-bar" role="meter" style="--bar-percentage: {{ energyDicePct }}%; --dnd5e-color-hp-1: #5a3a7a; --dnd5e-color-hp-2: #8b6aad; --dnd5e-color-hp-3: #7a5a9a;">
                        <div class="label"><span class="value">{{ system.energyDice.value }}</span><span class="separator">&sol;</span><span class="max">{{ system.energyDice.max }}</span></div>
                      </div>
                    </div>
                </div>
            </div>

            {{!-- Pontos de Armadura (Foco Defensivo) --}}
            <div class="meter-group">
                <div class="label roboto-condensed-upper">
                    <span>Pontos de Armadura</span>
                </div>
                <div style="display: flex; gap: 4px;">
                    {{#with system.armorPoints}}
                    <div class="meter sectioned hit-points armor-points-bar" style="flex:1; --dnd5e-color-hp-1: #4a5a6a; --dnd5e-color-hp-2: #8a9aaa; --dnd5e-color-hp-3: #6a7a8a;" role="meter" aria-valuemin="0" aria-valuenow="{{ value }}" aria-valuemax="{{ max }}">
                      <div class="progress hit-points armor-points-bar" role="meter" style="--bar-percentage: {{ @root.armorPct }}%; --dnd5e-color-hp-1: #4a5a6a; --dnd5e-color-hp-2: #8a9aaa; --dnd5e-color-hp-3: #6a7a8a;">
                        <div class="label">
                          <span class="value">{{ value }}</span>
                          <span class="separator">&sol;</span>
                          <span class="max">{{ max }}</span>
                        </div>
                        <input type="text" name="system.armorPoints.value" data-dtype="Number"
                               data-max="{{ max }}" placeholder="0" value="{{ value }}" hidden>
                      </div>
                    </div>
                    {{#if max}}
                    <button type="button" class="jj-foco-def-btn {{#if value}}active{{/if}}"
                            data-action="jj-foco-defensivo"
                            data-tooltip="{{#if value}}Desativar Foco Defensivo{{else}}Ativar Foco Defensivo ({{max}} Pontos de Armadura){{/if}}">
                      <i class="fas fa-shield-halved" inert></i>
                    </button>
                    {{/if}}
                    {{/with}}
                </div>
            </div>
        </div>

        {{!-- Death Saves --}}
        <div class="death-tray {{#if death.open}}open{{/if}}">
            <div class="death-saves">

                {{!-- Successes --}}
                <div class="pips" data-prop="system.attributes.death.success">
                    {{#each death.success}}
                    {{> ".pip" }}
                    {{/each}}
                </div>

                {{!-- Roll Death Save --}}
                {{#if editable}}
                <button type="button" class="death-save config-button unbutton" data-action="showConfiguration"
                        data-config="death" data-tooltip="DND5E.DeathSaveConfigure"
                        aria-label="{{ localize 'DND5E.DeathSaveConfigure' }}">
                    <i class="fas fa-cog" inert></i>
                </button>
                {{else}}
                <button type="button" class="{{ rollableClass }} death-save unbutton" data-action="roll"
                        data-type="deathSave" data-tooltip="DND5E.DeathSaveRoll"
                        aria-label="{{ localize 'DND5E.DeathSaveRoll' }}">
                    <dnd5e-icon src="systems/onepiece-system/icons/svg/statuses/dead.svg"></dnd5e-icon>
                </button>
                {{/if}}

                {{!-- Failures --}}
                <div class="pips" data-prop="system.attributes.death.failure">
                    {{#each death.failure}}
                    {{> ".pip" }}
                    {{/each}}
                </div>

            </div>

            <button type="button" class="death-tab card-tab horizontal unbutton always-interactive"
                    data-action="toggleDeathTray" {{#if death.open~}}
                    data-tooltip="DND5E.DeathSaveShow" aria-label="{{ localize 'DND5E.DeathSaveShow' }}"{{else~}}
                    data-tooltip="DND5E.DeathSaveHide" aria-label="{{ localize 'DND5E.DeathSaveHide' }}"{{/if}}>
                <i class="fas fa-skull" inert></i>
            </button>
        </div>

    </div>

    {{!-- Favorites --}}
    <div class="favorites">
        <div class="jj-favorites-header">
          <h3 class="icon">
              <i class="fas fa-bookmark" inert></i>
              <span class="roboto-upper">{{ localize "DND5E.Favorites" }}</span>
          </h3>
          <div class="jj-gerar-aura-box">
            <button type="button" class="jj-gerar-aura-pill"
                    data-action="jj-gerar-aura"
                    data-tooltip="Gerar Pontos de Poder">
              <i class="fas fa-bolt" inert></i>
            </button>
          </div>
        </div>
        <ul class="unlist">
            {{#each favorites}}

            {{!-- Favorite --}}
            <li class="{{#if itemId}}item-tooltip{{/if}} {{ type }} {{~#if suppressed}} suppressed{{/if}}
                {{~#if draggable}} draggable{{/if}}" data-favorite-id="{{ id }}"
                {{#if key}}data-key="{{ key }}"{{/if}}
                {{#if itemId}}data-item-id="{{ itemId }}"{{/if}}
                {{#if effectId}}data-effect-id="{{ effectId }}" data-action="useFavorite"{{/if}}
                {{#if parentId}}data-parent-id="{{ parentId }}"{{/if}}
                {{#if activityId}}data-activity-id="{{ activityId }}" data-action="useFavorite"{{/if}}
                {{#if reference}}data-reference-tooltip="{{ reference }}"{{/if}}
                {{#if method}}data-method="{{ method }}"{{/if}}
                {{#if level}}data-level="{{ level }}"{{/if}}>

                {{!-- Icon --}}
                <figure>
                    <img class="gold-icon" alt="{{ title }}" src="{{ img }}">

                    {{!-- Favorite Deletion --}}
                    {{#if @root.editable}}
                    <button type="button" class="deletion-control unbutton" data-action="deleteFavorite"
                            data-tooltip-class data-tooltip-direction data-tooltip="DND5E.FavoriteRemove"
                            aria-label="{{ localize 'DND5E.FavoriteRemove' }}">
                        <i class="fas fa-circle-xmark" inert></i>
                    </button>
                    {{/if}}
                </figure>

                {{!-- Name --}}
                <div class="name-stacked {{ rollableClass }}" role="button" data-action="useFavorite">
                    <span class="title">{{ title }}</span>
                    {{#if subtitle}}
                    <span class="subtitle">{{{ subtitle }}}</span>
                    {{/if}}
                </div>

                {{!-- Info --}}
                <div class="info">
                    <div class="primary {{ css }}">
                        {{!-- Item Uses & Capacity --}}
                        {{#if uses.max}}
                        {{#with uses}}
                        {{#if (and name @root.actor.isOwner)}}
                        <input type="text" class="uninput value" value="{{ value }}"
                               {{#unless ../bareName}}data-{{/unless}}name="{{ name }}"
                               data-dtype="Number" inputmode="numeric" pattern="[+=\-]?\d*">
                        {{else}}
                        <span class="value">{{ value }}</span>
                        {{/if}}
                        <span class="separator">&sol;</span>
                        <span class="max">{{ max }}</span>
                        {{/with}}

                        {{!-- Modifiers --}}
                        {{else if modifier includeZero=true}}
                        {{ dnd5e-formatModifier modifier }}

                        {{!-- Passive Score --}}
                        {{#if passive}}
                        <span class="passive">({{ passive }})</span>
                        {{/if}}

                        {{!-- Saves --}}
                        {{else if save.dc.value}}
                        {{#with save}}
                        <span class="ability">
                            {{ ability }}
                        </span>
                        <span class="value">{{ dc.value }}</span>
                        {{/with}}

                        {{!-- Other Value --}}
                        {{else if value includeZero=true}}
                        <span class="value">{{ value }}</span>

                        {{!-- Quantity --}}
                        {{else if quantity}}
                        <span class="sign">&times;</span>
                        <span class="value">{{ quantity }}</span>

                        {{!-- Toggleable --}}
                        {{else if toggle.applicable}}
                        <i class="fas fa-toggle-{{#if toggle.value}}on{{else}}off{{/if}}"></i>

                        {{!-- Legacy Resources --}}
                        {{else if resource}}
                        {{#if @root.actor.isOwner}}
                        <input type="text" class="uninput value" value="{{ resource.value }}"
                               data-dtype="Number" name="system.{{ id }}.value" inputmode="numeric"
                               pattern="[+=\-]?\d*">
                        {{else}}
                        <span class="value">{{ resource.value }}</span>
                        {{/if}}
                        <span class="separator">&sol;</span>
                        {{#if @root.editable}}
                        <input type="text" class="uninput max" value="{{ resource.source.max }}"
                               data-dtype="Number" name="system.{{ id }}.max" inputmode="numeric"
                               pattern="[+=\-]?\d*">
                        {{else}}
                        <span class="max">{{ resource.max }}</span>
                        {{/if}}
                        {{/if}}
                    </div>
                    <div class="secondary">
                        {{!-- Quantity --}}
                        {{#if (and uses quantity)}}
                        <span class="quantity">&times; {{ quantity }}</span>

                        {{!-- Range --}}
                        {{else if range.value}}
                        {{#with range}}
                        <span class="range">
                            {{ value }}
                            {{#if long}}&sol; {{ long }}{{/if}}
                            {{ units }}
                        </span>
                        {{/with}}

                        {{!-- Reach --}}
                        {{else if range.reach}}
                        <span class="range">{{ range.reach }} {{ range.units }}</span>
                        {{/if}}
                    </div>
                </div>

            </li>

            {{/each}}

            {{!-- Drop Indicator --}}
            <li class="drop roboto-upper">{{ localize "DND5E.FavoriteDrop" }}</li>
        </ul>

        {{!-- Explosão Defensiva + Energia Reversa — layout adaptativo --}}
        {{#if actor.system.manipulation.abilities.explosaoDefensiva.unlocked}}
        <div class="jj-habilidades-row
          {{#if actor.system.manipulation.abilities.energiaReversa.unlocked}}jj-habilidades-duo{{/if}}">

          {{!-- Explosão Defensiva --}}
          <filigree-box class="jj-expdef-box" id="jj-expdef-sidebar-{{actor.id}}">
            <h3 class="jj-expdef-header">
              <i class="fas fa-shield-halved" inert></i>
              <span>Explosão Defensiva</span>
            </h3>
            <div class="jj-expdef-btn-wrap">
              <button type="button" class="jj-expdef-trigger-btn" data-action="jj-expdef-trigger"
                      data-actor-id="{{ actor.id }}"
                      data-tooltip="Gastar PP para reduzir o próximo dano recebido">
                <i class="fas fa-shield-halved" inert></i>
                <span>Redução</span>
              </button>
            </div>
          </filigree-box>

          {{!-- Energia Reversa — só aparece se desbloqueada --}}
          {{#if actor.system.manipulation.abilities.energiaReversa.unlocked}}
          <filigree-box class="jj-enrev-box" id="jj-enrev-sidebar-{{actor.id}}">
            <h3 class="jj-enrev-header">
              <i class="fas fa-heart-pulse" inert></i>
              <span>Energia Reversa</span>
            </h3>
            <div class="jj-expdef-btn-wrap">
              <button type="button" class="jj-enrev-trigger-btn" data-action="jj-enrev-trigger"
                      data-actor-id="{{ actor.id }}"
                      data-tooltip="Gastar PP para se curar (1d4 PV por PP)">
                <i class="fas fa-heart-pulse" inert></i>
                <span>Curar</span>
              </button>
            </div>
          </filigree-box>
          {{/if}}

        </div>
        {{/if}}

        {{!-- Fulgor Negro — aparece se habilidade desbloqueada --}}
        {{#if fulgorNegro}}
        <filigree-box class="jj-fulgor-box">
            <h3 class="jj-fulgor-header">
                <i class="fas fa-bolt" inert></i>
                <span>Fulgor Negro</span>
            </h3>
            <div class="jj-fulgor-options">
                <div class="jj-fulgor-option">
                    <i class="fas fa-crosshairs" inert></i>
                    <span class="jj-fulgor-option-lbl">Principal</span>
                    <input type="number"
                        name="flags.onepiece-system.fulgorPrimaria"
                        value="{{ fulgorPrimaria }}"
                        min="1" max="20" />
                </div>
                <div class="jj-fulgor-option">
                    <i class="fas fa-dice-d20" inert></i>
                    <span class="jj-fulgor-option-lbl">Secundária</span>
                    <input type="number"
                        name="flags.onepiece-system.fulgorSecundaria"
                        value="{{ fulgorSecundaria }}"
                        min="1" max="20" />
                </div>
            </div>
            <div class="jj-fulgor-zona-wrap">
                <button type="button"
                    class="jj-fulgor-zona-btn {{#if fulgorZona}}active{{/if}}"
                    data-action="jj-fulgor-zona">
                    <i class="fas fa-eye" inert></i>
                    <span>{{#if fulgorZona}}Desativar Zona{{else}}Ativar Zona{{/if}}</span>
                </button>
            </div>
        </filigree-box>
        {{/if}}

        {{!-- Seis Olhos — aparece se o item Seis Olhos estiver na ficha --}}
        {{#if seisOlhos}}
        <filigree-box class="jj-seis-olhos-box">
            <h3 class="jj-seis-olhos-header">
                <i class="fas fa-eye" inert></i>
                <span>Seis Olhos</span>
            </h3>
            <div class="jj-seis-olhos-options">
                <label class="jj-seis-olhos-option {{#if (eq seisOlhosMode 'sealed')}}active{{/if}}">
                    <input type="radio" name="flags.onepiece-system.seisOlhosMode" value="sealed"
                           {{#if (eq seisOlhosMode 'sealed')}}checked{{/if}}>
                    <div class="jj-seis-olhos-btn">
                        <i class="fas fa-eye-slash" inert></i>
                        <span>Selado</span>
                    </div>
                </label>
                <label class="jj-seis-olhos-option {{#if (eq seisOlhosMode 'full')}}active{{/if}}">
                    <input type="radio" name="flags.onepiece-system.seisOlhosMode" value="full"
                           {{#if (eq seisOlhosMode 'full')}}checked{{/if}}>
                    <div class="jj-seis-olhos-btn">
                        <i class="fas fa-eye" inert></i>
                        <span>Poder Completo</span>
                    </div>
                </label>
            </div>
            {{#if (eq seisOlhosMode 'full')}}
            <div class="jj-seis-olhos-warning">
                <i class="fas fa-skull" inert></i> 2d8 dano psíquico no início do turno
            </div>
            {{/if}}
        </filigree-box>
        {{/if}}

        {{!-- Expansão de Domínio (Maestria 7) — aparece com Domínio Incompleto + Barreira Vazia --}}
        {{#if showExpansaoDominio}}
        <filigree-box class="jj-dominio-box">
            <h3 class="jj-dominio-header">
                <i class="fas fa-circle-nodes" inert></i>
                <span>Expansão de Domínio</span>
            </h3>
            <div class="jj-dominio-btn-wrap">
                <button type="button" class="jj-dominio-trigger-btn {{#if dominioExpandido}}expandido{{/if}}"
                        data-action="jj-expansao-dominio"
                        data-tooltip="{{#if dominioExpandido}}Expandir o domínio (1×/combate). Botão direito: configurar técnica/GIF.{{else}}Tentar expandir o domínio (1d20, 20 natural). 1×/combate. Botão direito: configurar.{{/if}}">
                    <i class="fas fa-circle-nodes" inert></i>
                    <span>{{#if dominioExpandido}}Expandir{{else}}Tentar Expandir{{/if}}</span>
                </button>
            </div>
        </filigree-box>
        {{/if}}

    </div>
</div>

{{#*inline ".pip"}}
<button type="button" class="{{ classes }}" data-action="togglePip" data-n="{{ n }}" data-tooltip="{{ tooltip }}"
        aria-label="{{ label }}" aria-pressed="{{ filled }}"></button>
{{/inline}}



