  "compatibility": {
    "minimum": "14.360",
    "verified": "14"
  },
  "url": "https://github.com/rezendesjoao/oprpg-system",
  "manifest": "https://github.com/rezendesjoao/oprpg-system/releases/latest/download/system.json",
  "download": "https://github.com/rezendesjoao/oprpg-system/releases/latest/download/system.zip",
  "authors": [
    {
      "name": "Joao Rezende",
      "url": "https://github.com/rezendesjoao/oprpg-system",
      "flags": {}
    }
  ],
  "esmodules": [
